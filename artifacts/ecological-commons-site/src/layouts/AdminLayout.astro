---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <title>{title} — An Ecological Commons</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="background-color: var(--color-bg-nav); min-height: 100vh;">
    <header style="border-bottom: 1px solid var(--color-border); background-color: var(--color-bg-nav);">
      <div style="max-width: 720px; margin: 0 auto; padding: 1rem 1.5rem;">
        <nav style="display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; align-items: center;">
          <a href="/" class="tab-link">An Ecological Commons</a>
          <a href="/#trust-groups" class="tab-link">About the Trust Layer</a>
        </nav>
      </div>
    </header>
    <main style="padding: 3rem 1.5rem;">
      <slot />
    </main>
  </body>
</html>
