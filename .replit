modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mcp-server: MCP Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "gbif-integration-check"

[[workflows.workflow]]
name = "artifacts/mcp-server: MCP Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mcp-server run dev"

[[workflows.workflow]]
name = "gbif-integration-check"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FERNS_API_BASE_URL=http://localhost:8080 pnpm --filter @workspace/ferns-audit run gbif-check"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-drive:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
packages = ["nano"]
channel = "stable-25_05"

[userenv]

[userenv.shared]

[userenv.production]
FERNS_API_BASE_URL = "https://ferns-eco-data.replit.app"
